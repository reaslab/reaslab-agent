{
  "name": "reaslab-agent",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test --timeout 30000",
    "test:acp-matrix": "node -e \"const { spawnSync } = require('node:child_process'); const result = spawnSync('bun', ['test', '--timeout', '120000', 'tests/integration/acp-model-matrix.test.ts'], { stdio: 'inherit', shell: true, env: { ...process.env, ACP_MODEL_MATRIX_MODE: 'required' } }); process.exit(result.status ?? 1)\"",
    "db": "bun drizzle-kit"
  },
  "imports": {
    "#db": {
      "bun": "./src/storage/db.bun.ts",
      "node": "./src/storage/db.node.ts",
      "default": "./src/storage/db.bun.ts"
    }
  },
  "exports": {
    "./*": "./src/*.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "2.0.65",
    "@ai-sdk/openai": "2.0.89",
    "@ai-sdk/openai-compatible": "1.0.32",
    "@ai-sdk/provider": "2.0.1",
    "@ai-sdk/provider-utils": "3.0.21",
    "@effect/platform-node": "4.0.0-beta.35",
    "@modelcontextprotocol/sdk": "1.25.2",
    "@pierre/diffs": "1.1.0-beta.18",
    "ai": "5.0.124",
    "chokidar": "4.0.3",
    "cross-spawn": "^7.0.6",
    "decimal.js": "^10.6.0",
    "diff": "8.0.2",
    "drizzle-orm": "1.0.0-beta.19-d95b7a4",
    "effect": "4.0.0-beta.35",
    "fuzzysort": "^3.1.0",
    "glob": "13.0.5",
    "gray-matter": "4.0.3",
    "ignore": "7.0.5",
    "jsonc-parser": "3.3.1",
    "mime-types": "3.0.2",
    "minimatch": "10.0.3",
    "partial-json": "0.1.7",
    "remeda": "2.26.0",
    "semver": "^7.6.3",
    "strip-ansi": "7.1.2",
    "tree-sitter-bash": "0.25.0",
    "turndown": "7.2.0",
    "ulid": "3.0.1",
    "web-tree-sitter": "0.25.10",
    "which": "6.0.1",
    "xdg-basedir": "5.1.0",
    "zod": "4.1.8",
    "zod-to-json-schema": "3.24.5"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/cross-spawn": "6.0.6",
    "@types/mime-types": "3.0.1",
    "@types/semver": "^7.5.8",
    "@types/turndown": "5.0.5",
    "@types/which": "3.0.4",
    "drizzle-kit": "1.0.0-beta.19-d95b7a4",
    "typescript": "5.8.2",
    "vscode-languageserver-types": "3.17.5"
  }
}
