{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ESNext"],
    "types": [],
    "paths": {
      "@/*": ["./src/*"],
      "@reaslab-agent/util/*": ["./src/util-pkg/*"],
      "@reaslab-agent/plugin": ["./src/plugin/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
